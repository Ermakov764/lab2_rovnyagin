# Скопируйте в .env и подставьте свои значения (файл .env не коммитится).
#
# Имя БД: POSTGRES_DB (контейнер postgres) и DBNAME (приложение) должны совпадать.
#   Пример из таблицы курса (Ермаков Л. А.): POSTGRES_DB=hl3, DBNAME=hl3, SCHEMANAME=hl3
#   Локально «всё в одном» — lab2_db / public (как ниже).
# При смене POSTGRES_DB на уже существующем томе PostgreSQL выполните CREATE DATABASE
# или docker compose down -v и поднимите стек заново (данные БД обнулятся).
#
# --- Лаб. 7 (узел БД hl12.zil, узел приложения — своя ВМ) ---
# На hl12: docker compose -f docker-compose.lab7-db.yml up -d
#   Задайте POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD;
#   при пробросе Postgres на хост не на 5432: POSTGRES_PUBLISH_PORT=2312 (и на ВМ приложения DBPORT=2312)
# На ВМ приложения: docker compose -f docker-compose.lab7-app.yml up -d
#   DBHOST=hl12.zil  DBPORT=5432  (или тот порт, который проброшен на hl12)
#   DBNAME и SCHEMANAME — по таблице курса (часто одно и то же, напр. hl3)

# Имя образа на Docker Hub (ТЗ: токен, docker login; на ВМ поднимать через pull, не через compose build app).
# Пример: docker compose pull app && docker compose up -d
# Сборка/push отдельно: docker build -t "$DOCKER_IMAGE_APP" . && docker push "$DOCKER_IMAGE_APP"
DOCKER_IMAGE_APP=lavrentiyermakov/lab2_rovnyagin:latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=lab2_password
POSTGRES_DB=lab2_db

# JDBC собирается из DBHOST/DBPORT/DBNAME/SCHEMANAME (см. application.properties).
# Для docker-compose.yml (app + postgres в одной сети) по умолчанию DBHOST=postgresdb.
# Для docker-compose.lab7-app.yml по умолчанию DBHOST=hl12.zil.
DBHOST=postgresdb
DBPORT=5432
DBNAME=lab2_db
SCHEMANAME=public

SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=lab2_password

SERVER_TOMCAT_THREADS_MAX=200
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

# Лимиты контейнера приложения (лаб. 6): меняйте APP_CPU_LIMIT для серии экспериментов (шаг 0.5 CPU).
APP_CPU_LIMIT=1.50
APP_MEMORY_LIMIT=1536M
APP_CPU_RESERVATION=0.25
APP_MEMORY_RESERVATION=256M
