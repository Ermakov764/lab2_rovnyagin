# Скопируйте в .env и подставьте свои значения (файл .env не коммитится).
# Имя БД из таблицы курса (например hl3) должно совпадать в POSTGRES_DB и в JDBC URL.

# Имя образа приложения на Docker Hub (создайте репозиторий на hub.docker.com, токен с правами Read & Write для push).
DOCKER_IMAGE_APP=lavrentiyermakov/lab2_rovnyagin:latest

POSTGRES_USER=postgres
POSTGRES_PASSWORD=lab2_password
POSTGRES_DB=lab2_db

SPRING_DATASOURCE_URL=jdbc:postgresql://postgresdb:5432/lab2_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=lab2_password

SERVER_TOMCAT_THREADS_MAX=200
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

# Лимиты контейнера приложения (лаб. 6): меняйте APP_CPU_LIMIT для серии экспериментов (шаг 0.5 CPU).
APP_CPU_LIMIT=1.50
APP_MEMORY_LIMIT=1536M
APP_CPU_RESERVATION=0.25
APP_MEMORY_RESERVATION=256M
