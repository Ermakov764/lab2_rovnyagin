    {
      "name": "Tickets API (/api)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var sessionDate = pm.environment.get(\"sessionDate\");",
              "if (!sessionDate || String(sessionDate).trim() === \"\") {",
              "    var tomorrow = new Date();",
              "    tomorrow.setDate(tomorrow.getDate() + 1);",
              "    var yyyy = tomorrow.getFullYear();",
              "    var mm = String(tomorrow.getMonth() + 1).padStart(2, \"0\");",
              "    var dd = String(tomorrow.getDate()).padStart(2, \"0\");",
              "    pm.environment.set(\"sessionDate\", yyyy + \"-\" + mm + \"-\" + dd);",
              "}"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "GET /api/tickets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets"
          }
        },
        {
          "name": "POST /api/tickets",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var requiredVars = [\"filmId\", \"viewerId\"];",
                  "var missingVars = requiredVars.filter(function (name) {",
                  "    var value = pm.environment.get(name);",
                  "    return !value || String(value).trim() === \"\";",
                  "});",
                  "if (missingVars.length > 0) {",
                  "    throw new Error(\"Missing env vars: \" + missingVars.join(\", \") + \". Run POST /api/films and POST /api/viewers first.\");",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test(\"Response id is number\", function () {",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "});",
                  "pm.environment.set(\"ticketId\", String(json.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"viewerId\": {{viewerId}},\n  \"filmId\": {{filmId}},\n  \"sessionDate\": \"{{sessionDate}}\",\n  \"sessionTime\": \"19:00:00\",\n  \"seatNumber\": \"C5\",\n  \"price\": 15.5\n}"
            },
            "url": "{{baseUrl}}/api/tickets"
          }
        },
        {
          "name": "GET /api/tickets/:id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/{{ticketId}}"
          }
        },
