    {
      "name": "Films API (/api)",
      "item": [
        {
          "name": "GET /api/films",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/films"
          }
        },
        {
          "name": "POST /api/films",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.test(\"Response id is number\", function () {",
                  "    pm.expect(json.id).to.be.a(\"number\");",
                  "});",
                  "pm.environment.set(\"filmId\", String(json.id));",
                  "if (json.title) {",
                  "    pm.environment.set(\"filmTitle\", json.title);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{filmTitle}}\",\n  \"genre\": \"Sci-Fi\",\n  \"durationMinutes\": 148\n}"
            },
            "url": "{{baseUrl}}/api/films"
          }
        },
